# Transpose local development environment example
# Copy to .env and fill in real values.

TRANSPOSE_POSTGRES_HOST=your-postgres-server.postgres.database.azure.com
TRANSPOSE_POSTGRES_PORT=5432
TRANSPOSE_POSTGRES_DB=transpose
TRANSPOSE_POSTGRES_USER=your-user-or-managed-identity-client-id
TRANSPOSE_POSTGRES_PASSWORD=

TRANSPOSE_DOC_INTELLIGENCE_ENDPOINT=https://your-docintel.cognitiveservices.azure.com/
TRANSPOSE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
TRANSPOSE_OPENAI_DEPLOYMENT=gpt-4o

# Blob data-plane endpoint for private containers (source-pdfs, output, book-workspaces)
TRANSPOSE_BLOB_STORAGE_ACCOUNT_URL=https://yourstorage.blob.core.windows.net

# Public Azure Static Website endpoint for landing pages and public downloads.
# Derive after running scripts/azure-setup.sh:
#   az storage account show --name <account> --resource-group <rg> --query 'primaryEndpoints.web' -o tsv
TRANSPOSE_BLOB_STATIC_WEBSITE_URL=https://yourstorage.z13.web.core.windows.net/

# Optional local override for landing-page copy
TRANSPOSE_WORKSPACE_TRANSLATOR_NOTE=

# Optional for local telemetry
TRANSPOSE_APPLICATIONINSIGHTS_CONNECTION_STRING=

# Microsoft Entra ID app registration for /admin/* (MSAL.js PKCE; no client secret).
# Values are public-by-design but kept out of source for environment portability.
# See docs/auth.md.
ENTRA_TENANT_ID=
ENTRA_ADMIN_CLIENT_ID=

# TTS / Audiobook (Stage 8)
# Provider: azure | elevenlabs | openai
TRANSPOSE_TTS_PROVIDER=azure
TRANSPOSE_TTS_VOICE=en-US-AndrewMultilingualNeural
TRANSPOSE_TTS_SPEECH_KEY=
TRANSPOSE_TTS_SPEECH_REGION=eastus
TRANSPOSE_TTS_SPEECH_ENDPOINT=
